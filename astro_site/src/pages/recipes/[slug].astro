---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();

type Ingredient = CollectionEntry<'recipes'>['data']['ingredients'][number];

const dishMap = new Map<string, Ingredient[]>();
for (const ingredient of recipe.data.ingredients) {
  if (!dishMap.has(ingredient.dish)) {
    dishMap.set(ingredient.dish, []);
  }
  dishMap.get(ingredient.dish)!.push(ingredient);
}

const dishes = Array.from(dishMap.entries()).sort(([a], [b]) => a.localeCompare(b));

function dishVolumeMl(ingredients: Ingredient[]): number {
  let total = 0;
  for (const ing of ingredients) {
    if (ing.unit === 'ml' || ing.unit === 'g') {
      total += ing.amount;
    } else if (ing.dish_ml != null) {
      total += ing.dish_ml;
    }
  }
  return total;
}

function formatMinutes(minutes: number): string {
  const totalSeconds = Math.round(minutes * 60);
  if (totalSeconds < 60) return `${totalSeconds} sec`;
  const hrs = Math.floor(totalSeconds / 3600);
  const mins = Math.floor((totalSeconds % 3600) / 60);
  if (hrs === 0) return `${mins} min`;
  return mins === 0 ? `${hrs} hr` : `${hrs} hr ${mins} min`;
}

function formatIngredient(ing: Ingredient): string {
  let s = `${ing.amount}`;
  if (ing.unit) s += ` ${ing.unit}`;
  s += ` ${ing.name}`;
  if (ing.prep) s += `, ${ing.prep}`;
  return s;
}

// Optimized image URL for JSON-LD
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
let imageUrl: string | undefined;
if (recipe.data.featuredImage) {
  const optimized = await getImage({ src: recipe.data.featuredImage });
  imageUrl = new URL(optimized.src, siteOrigin).href;
}

// Schema.org JSON-LD
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org/',
  '@type': 'Recipe',
  'name': recipe.data.title,
  'url': Astro.url.href,
  'author': {
    '@type': 'Person',
    'name': 'Greg Thomas',
    'url': 'https://gregmakes.xyz',
  },
  'datePublished': recipe.data.date.toISOString().split('T')[0],
  'recipeIngredient': recipe.data.ingredients.map(formatIngredient),
};
if (imageUrl) jsonLd['image'] = imageUrl;
if (recipe.data.tags?.length) jsonLd['keywords'] = recipe.data.tags.join(', ');
if (recipe.data.steps.length > 0) {
  jsonLd['recipeInstructions'] = recipe.data.steps.map((step, i) => ({
    '@type': 'HowToStep',
    'position': i + 1,
    'text': step.text,
    'url': `${Astro.url.href}#step-${i}`,
  }));
}
if (recipe.data.equipment.length > 0) {
  jsonLd['tool'] = recipe.data.equipment.map(t => ({ '@type': 'HowToTool', 'name': t }));
}
---

<Layout title={recipe.data.title}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <article class="recipe h-recipe">
    <h1 class="p-name">{recipe.data.title}</h1>

    <p class="recipe-byline">
      By <span class="p-author h-card">
        <a class="p-name u-url" href="https://gregmakes.xyz">Greg</a>
      </span>
      {' · '}
      <time class="dt-published" datetime={recipe.data.date.toISOString()}>
        {recipe.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </p>

    {recipe.data.featuredImage && (
      <div class="featured-image">
        <Image
          class="u-photo"
          src={recipe.data.featuredImage}
          alt={`Featured image for ${recipe.data.title}`}
          width={800}
          height={500}
          loading="eager"
        />
      </div>
    )}

    {recipe.data.attribution && (
      <p class="attribution"><em>{recipe.data.attribution}</em></p>
    )}

    {recipe.data.tags && recipe.data.tags.length > 0 && (
      <ul class="tags" style="list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap;">
        {recipe.data.tags.map(tag => <li class="p-category"><small>{tag}</small></li>)}
      </ul>
    )}

    <section class="equipment">
      <h2>Equipment</h2>
      <ul>
        {recipe.data.equipment.map(item => (
          <li>
            {item}
            {recipe.data.prepOnly.includes(item) && (
              <span class="prep-only">prep only</span>
            )}
          </li>
        ))}
      </ul>
    </section>

    <div class="recipe-body">
      <section class="ingredients">
        <h2>Ingredients</h2>
        <div id="scale-control" hidden>
          <span>Scale</span>
          <input type="number" id="recipe-scale" min="0.1" step="any" value="1" />
          <span>×</span>
        </div>
        {dishes.map(([dish, ingredients]) => {
          const flagged = dish.length === 1 && dishVolumeMl(ingredients) >= 90;
          const label = dish.length === 1 ? `Dish ${dish}` : dish;
          return (
            <div class="dish-group">
              <h3>{label}{flagged && ' *'}</h3>
              <ul>
                {ingredients.map((ing, i) => {
                  const id = `dish-${dish}-${i}`;
                  return (
                    <li class="p-ingredient">
                      <input type="checkbox" id={id} />
                      <label for={id}>
                        <span class="ing-amount" data-amount={ing.amount} data-unit={ing.unit ?? ''}>{ing.amount}{ing.unit ? ` ${ing.unit}` : ''}</span>{' '}{ing.name}{ing.prep ? `, ${ing.prep}` : ''}
                      </label>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })}
        {dishes.some(([dish, ingredients]) => dish.length === 1 && dishVolumeMl(ingredients) >= 90) && (
          <p><small>* larger than my standard 90ml prep dish</small></p>
        )}
      </section>

      <section class="steps">
        <h2>Steps</h2>
        <div class="e-instructions">
          {recipe.data.steps.length > 0 ? (
            <ol>
              {recipe.data.steps.map((step, i) => (
                <li id={`step-${i}`}>
                  <input type="checkbox" id={`step-cb-${i}`} />
                  <div class="step-content">
                    <label for={`step-cb-${i}`}>{step.text}</label>
                    {(step.timers.length > 0 || step.lastUse.length > 0) && (
                      <div class="step-meta">
                        {step.timers.map(t => (
                          <span class="timer">{formatMinutes(t.minutes)} · {t.label}</span>
                        ))}
                        {step.lastUse.map(eq => (
                          <span class="last-use">✓ {eq}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          ) : (
            <Content />
          )}
        </div>
      </section>
    </div>
  </article>
</Layout>

<style>
  input[type="checkbox"]:checked + label {
    color: grey;
    text-decoration: line-through;
  }
</style>

<script>
  const control = document.getElementById('scale-control');
  const input = document.getElementById('recipe-scale') as HTMLInputElement | null;
  if (control && input) {
    control.hidden = false;

    const FRACTIONS: [number, string][] = [
      [1/4, '¼'], [1/3, '⅓'], [1/2, '½'], [2/3, '⅔'], [3/4, '¾'],
    ];

    function formatCountable(value: number): string {
      if (value <= 0) return '0';
      const whole = Math.floor(value);
      const frac = value - whole;
      const match = FRACTIONS.find(([f]) => Math.abs(frac - f) < 0.05);
      if (frac < 0.05) return `${whole}`;
      if (match) return whole > 0 ? `${whole}${match[1]}` : match[1];
      return value.toFixed(1);
    }

    function formatMeasured(value: number): string {
      const r = Math.round(value * 10) / 10;
      return String(r);
    }

    input.addEventListener('input', () => {
      const scale = parseFloat(input.value);
      if (!(scale > 0)) return;
      document.querySelectorAll<HTMLElement>('.ing-amount').forEach(el => {
        const base = parseFloat(el.dataset.amount!);
        const unit = el.dataset.unit!;
        const scaled = base * scale;
        const formatted = unit ? formatMeasured(scaled) : formatCountable(scaled);
        el.textContent = unit ? `${formatted} ${unit}` : formatted;
      });
    });
  }
</script>
